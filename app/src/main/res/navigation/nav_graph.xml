<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/restaurantsFragment">

    <fragment
        android:id="@+id/restaurantsFragment"
        android:name="com.example.restaurantapp.presentation.restaurants.RestaurantsFragment"
        android:label="Рестораны"
        tools:layout="@layout/fragment_restaurants" >
        <action
            android:id="@+id/action_restaurantsFragment_to_restaurantDetailFragment"
            app:destination="@id/restaurantDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/newsFragment"
        android:name="com.example.restaurantapp.presentation.news.NewsFragment"
        android:label="Новости"
        tools:layout="@layout/fragment_news" />
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.restaurantapp.presentation.profile.ProfileFragment"
        android:label="Профиль"
        tools:layout="@layout/fragment_profile" >
        <action
            android:id="@+id/action_profileFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/restaurantsFragment"
            app:popUpToInclusive="false" />
        <action
            android:id="@+id/action_profileFragment_to_personInfoFragment"
            app:destination="@id/personInfoFragment" />
        <action
            android:id="@+id/action_profileFragment_to_favoriteDishesFragment"
            app:destination="@id/favoriteDishesFragment" />
    </fragment>
    <fragment
        android:id="@+id/restaurantDetailsFragment"
        android:name="com.example.restaurantapp.presentation.details.RestaurantDetailsFragment"
        android:label="{restaurantName}"
        tools:layout="@layout/fragment_restaurant_details">

        <argument
            android:name="restaurantId"
            app:argType="integer" />
        <argument
            android:name="restaurantName"
            app:argType="string" />
        <action
            android:id="@+id/action_restaurantDetailsFragment_to_dishesFragment"
            app:destination="@id/dishesFragment" />
        <action
            android:id="@+id/action_restaurantDetailsFragment_to_dishDetailsFragment"
            app:destination="@id/dishDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/dishesFragment"
        android:name="com.example.restaurantapp.presentation.menu.DishesFragment"
        android:label="{categoryName}"
        tools:layout="@layout/fragment_dishes">

        <argument
            android:name="categoryId"
            app:argType="integer" />
        <argument
            android:name="categoryName"
            app:argType="string" />
        <action
            android:id="@+id/action_dishesFragment_to_dishDetailsFragment"
            app:destination="@id/dishDetailsFragment" />
    </fragment>
    <fragment
        android:id="@+id/dishDetailsFragment"
        android:name="com.example.restaurantapp.presentation.menu.DishDetailsFragment"
        android:label="fragment_dish_details"
        tools:layout="@layout/fragment_dish_details">

        <argument
            android:name="dishId"
            app:argType="integer" />
    </fragment>
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.restaurantapp.presentation.profile.LoginFragment"
        android:label="fragment_login"
        tools:layout="@layout/fragment_login" >
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_loginFragment_to_profileFragment"
            app:destination="@id/profileFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.restaurantapp.presentation.profile.RegisterFragment"
        android:label="fragment_register"
        tools:layout="@layout/fragment_register" >
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true"/>
        <action
            android:id="@+id/action_registerFragment_to_profileFragment"
            app:destination="@id/profileFragment"
            app:popUpTo="@id/registerFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/personInfoFragment"
        android:name="com.example.restaurantapp.presentation.profile.PersonInfoFragment"
        android:label="Мои данные"
        tools:layout="@layout/fragment_person_info" />
    <fragment
        android:id="@+id/favoriteDishesFragment"
        android:name="com.example.restaurantapp.presentation.favorite.FavoriteDishesFragment"
        android:label="Избранное"
        tools:layout="@layout/fragment_favorite_dishes" >
        <action
            android:id="@+id/action_favoriteDishesFragment_to_dishDetailsFragment"
            app:destination="@id/dishDetailsFragment" />
    </fragment>


</navigation>