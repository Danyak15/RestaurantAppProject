<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/restaurantsFragment">

    <fragment
        android:id="@+id/restaurantsFragment"
        android:name="com.example.restaurantapp.presentation.restaurants.RestaurantsFragment"
        android:label="fragment_restaurants"
        tools:layout="@layout/fragment_restaurants" >
        <action
            android:id="@+id/action_restaurantsFragment_to_restaurantDetailFragment"
            app:destination="@id/restaurantDetailsFragment" />
    </fragment>

    <fragment
        android:id="@+id/newsFragment"
        android:name="com.example.restaurantapp.presentation.news.NewsFragment"
        android:label="fragment_news"
        tools:layout="@layout/fragment_news" />
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.restaurantapp.presentation.profile.ProfileFragment"
        android:label="fragment_profile"
        tools:layout="@layout/fragment_profile" />
    <fragment
        android:id="@+id/restaurantDetailsFragment"
        android:name="com.example.restaurantapp.presentation.details.RestaurantDetailsFragment"
        android:label="fragment_restaurant_detail"
        tools:layout="@layout/fragment_restaurant_details">

        <argument
            android:name="restaurantId"
            app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/menuCategoriesFragment"
        android:name="com.example.restaurantapp.presentation.menu.MenuCategoriesFragment"
        android:label="fragment_menu_categories"
        tools:layout="@layout/fragment_menu_categories" >
        <action
            android:id="@+id/action_menuCategoriesFragment_to_menuItemsFragment"
            app:destination="@id/menuItemsFragment" />
    </fragment>
    <fragment
        android:id="@+id/bookFragment"
        android:name="com.example.restaurantapp.presentation.booking.BookFragment"
        android:label="fragment_book"
        tools:layout="@layout/fragment_book" />
    <fragment
        android:id="@+id/infoFragment"
        android:name="com.example.restaurantapp.presentation.info.InfoFragment"
        android:label="fragment_info"
        tools:layout="@layout/fragment_info" />
    <fragment
        android:id="@+id/menuItemsFragment"
        android:name="com.example.restaurantapp.presentation.menu.MenuItemsFragment"
        android:label="fragment_menu_items"
        tools:layout="@layout/fragment_menu_items">

        <argument
            android:name="categoryId"
            app:argType="integer" />
    </fragment>


</navigation>